VITE_SERVER_URL=https://qualified-jonie-h3lv0k-850ea925.koyeb.app

# ─── Ad Provider ───────────────────────────────────────────────────────────────
# auto   — detect by user locale: RU/CIS → Yandex, other → Google IMA (recommended)
# dev    — simulated countdown, no real ads
# ima    — force Google IMA for all users
# yandex — force Yandex YAN for all users
VITE_AD_PROVIDER=auto

# Google IMA — get tag URL from https://admanager.google.com
# Inventory → Ad units → New → Type: Rewarded → Generate tags
VITE_IMA_AD_TAG_URL=https://pubads.g.doubleclick.net/gampad/ads?...

# Yandex YAN — get block ID from https://partner.yandex.ru
# Sites → Ad blocks → Rewarded Video → copy "ownerId/blockId"
VITE_YANDEX_BLOCK_ID=123456/R-A-000000-1
